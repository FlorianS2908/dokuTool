{
  "name": "ihk-dokutool",
  "version": "2.0.0",
  "description": "Lokales IHK-Dokumentations-Prüftool mit OpenAI-Integration, DOCX/PDF-Analyse und Prüfbericht.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:timer-quiz": "esbuild src/client/timer-quiz/index.tsx --bundle --format=esm --platform=browser --jsx=automatic --outfile=public/timer-quiz.bundle.js",
    "build:ruleset": "node scripts/build-fiae-ruleset.mjs",
    "validate:rulesets": "node scripts/validate-rulesets.mjs",
    "test:review": "node scripts/test-review-workflow.mjs",
    "test:ai-config": "node scripts/test-ai-config.mjs",
    "test:prompt-assistant": "node scripts/test-prompt-assistant.mjs",
    "test:audit-report": "node scripts/test-audit-report.mjs",
    "test:functional": "node scripts/run-function-tests.mjs",
    "references:import": "node scripts/import-references.mjs",
    "references:scan": "node scripts/scan-references.mjs",
    "validate:references": "node scripts/validate-references.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "firebase-admin": "^13.6.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "openai": "latest",
    "pdf-parse": "^1.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
